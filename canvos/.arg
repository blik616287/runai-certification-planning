# CanvOS build arguments — Run:ai certification (Palette Edge)
# Repo: https://github.com/spectrocloud/CanvOS  (validated against PE_VERSION v4.9.21)
# Aligned to the upstream .arg.template. Produces the Kairos immutable OS + RKE2
# provider image that becomes the `edge-native-byoi` OS layer under test.
#
# K8s VERSION IS NOT SET HERE. Pass it on the build CLI to pin a single version:
#   ./earthly.sh +build-provider-images --K8S_VERSION=1.34.6 --ARCH=amd64
# (Leaving it unset makes CanvOS build EVERY rke2 version in k8s_version.json.)
# The resulting provider image tag `rke2-1.34.6-<CUSTOM_TAG>` MUST match the
# `edge-rke2` 1.34.6 pack tag in the profile.

CUSTOM_TAG=runai-cert
IMAGE_REGISTRY=<your-registry>            # e.g. ttl.sh/<uuid> or your governed registry
OS_DISTRIBUTION=ubuntu
IMAGE_REPO=palette-edge-runai
OS_VERSION=22.04
K8S_DISTRIBUTION=rke2                      # LOCKED — the distribution being certified
ISO_NAME=palette-edge-runai-installer
ARCH=amd64                                # LOCKED — amd64 cert kit
HTTPS_PROXY=
HTTP_PROXY=
UPDATE_KERNEL=false
CLUSTERCONFIG=spc.tgz
CIS_HARDENING=false
EDGE_CUSTOM_CONFIG=.edge-custom-config.yaml
FORCE_INTERACTIVE_INSTALL=false
