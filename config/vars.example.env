# Run:ai certification — required variables (TEMPLATE, no secrets committed)
# Copy to config/vars.env (gitignored) and fill in. Sources noted per line.

# ---- Cert kit (Phase 6, passed to `docker run`) ----
CONTROL_PLANE_URL=              # Run:ai control-plane URL (backend), e.g. https://runai.<domain>
CLUSTER_NAME_PREFIX=            # prefix for cluster objects the kit creates, e.g. cert-kit
CLUSTER_URL=                    # managed cluster URL
CONTROL_PLANE_ADMIN_USERNAME=   # Run:ai console admin (default demo: admin@run.ai — ROTATE)
CONTROL_PLANE_ADMIN_PASSWORD=   # Run:ai console admin password (default demo: <REDACTED-ROTATE> — ROTATE)
CERT_KIT_IMAGE=runai/certification-kit-amd64:latest   # amd64 kit (NVIDIA-supplied registry)

# ---- Palette cluster-profile variables ----
# AI-RA-RunAI-Cluster
RUNAI_CONTROL_PLANE_URL=        # -> spectro.var.runai-control-plane-url  (= CONTROL_PLANE_URL)
RUNAI_CLIENT_SECRET=            # -> spectro.var.runai-client-secret      (from Run:ai console: cluster install)
RUNAI_CLUSTER_UID=             # -> spectro.var.runai-cluster-uid         (from Run:ai console: after cluster create)
RUNAI_CLUSTER_URL=             # -> spectro.var.runai-cluster-url

# AI-RA-RunAI-Backend
RUNAI_BACKEND_URL=             # -> spectro.var.RunAIBackendURL           (backend FQDN)

# AI-RA-Infra-Agent / AI-RA-Core-plus-dra
METALLB_IP_RANGE=              # -> spectro.var.metallbIpRange            (LB pool, e.g. 10.0.0.240-10.0.0.250)
METALLB_L2_INTERFACE=          # -> spectro.var.metallbL2Interface        (node NIC, e.g. eth0)
KUBEVIP=                       # -> spectro.system.cluster.kubevip        (edge control-plane VIP)

# ---- CanvOS / Palette (Phase 1-2) ----
PALETTE_PROJECT_UID=68e6a683b6b66c6045d1b584   # ISC-Strategic-Alliance
PALETTE_API_KEY=               # Palette apiKey header (do NOT commit)
IMAGE_REGISTRY=                # CanvOS provider-image registry
EDGE_REGISTRATION_TOKEN=       # Palette edge host token (canvos/user-data)
